{
  "name": "dealflow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @dealflow/e2e test:e2e",
    "dev": "pnpm -r --parallel --filter @dealflow/api --filter @dealflow/web dev",
    "dev:env": "docker compose -f infra/compose/docker-compose.dev.yml up -d",
    "dev:env:down": "docker compose -f infra/compose/docker-compose.dev.yml down",
    "dev:env:reset": "docker compose -f infra/compose/docker-compose.dev.yml down -v"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "@eslint/js": "^9.13.0",
    "typescript-eslint": "^8.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
