# Normalize all text files to LF in the repo and in working trees.
# .editorconfig already enforces LF in editors; this enforces it in git.
* text=auto eol=lf

# Lockfiles + generated files
pnpm-lock.yaml text eol=lf

# Binary Office / PDF files — never LF-normalize, never diff as text
*.pptx binary
*.docx binary
*.xlsx binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
