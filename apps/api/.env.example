# Copy this file to apps/api/.env and fill in real values.
# apps/api/.env is gitignored; this file is committed as documentation.

DATABASE_URL=postgres://dealflow:dealflow@localhost:5432/dealflow
NODE_ENV=development
PORT=3001
DEPLOYMENT_MODE=saas
CORS_ORIGIN=http://localhost:5173

# AI providers (optional). The runtime tries them in order Claude → Gemini → Grok.
# Any provider without a key is skipped. If all keys are missing, AI is disabled.
# Errors from one provider transparently fall through to the next.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-4
