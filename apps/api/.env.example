# Copy this file to apps/api/.env and fill in real values.
# apps/api/.env is gitignored; this file is committed as documentation.

DATABASE_URL=postgres://dealflow:dealflow@localhost:5432/dealflow
NODE_ENV=development
PORT=3001
DEPLOYMENT_MODE=saas
CORS_ORIGIN=http://localhost:5173

# Required: a 32-byte (base64-encoded) key used to encrypt per-org integration
# secrets (AI API keys + SMTP password). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Treat this like a database password — if you lose it you lose every stored secret.
INTEGRATION_ENCRYPTION_KEY=replace-me-with-a-base64-32-byte-key

# AI provider keys + SMTP credentials are configured per-org via the Settings
# UI (http://localhost:5173/app/settings), encrypted at rest using the
# INTEGRATION_ENCRYPTION_KEY above. No provider env vars are needed.

# Email tracking (outbound v1)
# Public URL where the API is reachable from the internet. Used to build
# absolute tracking pixel + click-redirect URLs that go in outgoing emails.
PUBLIC_API_URL=http://localhost:3000

# Public URL where the *web app* is reachable. Used to build invitation
# accept links that go in invite emails (e.g. ${PUBLIC_WEB_URL}/invite/<token>).
# Defaults to the CORS_ORIGIN default in dev; set explicitly in production.
PUBLIC_WEB_URL=http://localhost:5173

# EngineMailer transactional email. The API key is set PER ORG in Settings →
# Email (stored encrypted), so it is NOT an env var. The webhook secret below is
# the shared key embedded in the EngineMailer webhook callback URL as
# `?key=<secret>` (EngineMailer has no HMAC signing) and verified on every
# inbound POST to /api/v1/webhooks/engine-mailer. Generate with: openssl rand -hex 24
ENGINE_MAILER_WEBHOOK_SECRET=
