# Copy this file to apps/api/.env and fill in real values.
# apps/api/.env is gitignored; this file is committed as documentation.

DATABASE_URL=postgres://dealflow:dealflow@localhost:5432/dealflow
NODE_ENV=development
PORT=3001
DEPLOYMENT_MODE=saas
CORS_ORIGIN=http://localhost:5173

# AI providers (optional). The runtime tries them in order Claude → Gemini → Grok.
# Any provider without a key is skipped. If all keys are missing, AI is disabled.
# Errors from one provider transparently fall through to the next.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-4

# Email (optional). Resend is the supported provider. RESEND_API_KEY is required
# to enable sending; RESEND_FROM_EMAIL must be a verified domain in your Resend
# dashboard. RESEND_FROM_NAME shows in the From line ("Name <email>").
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@your-domain.com
# RESEND_FROM_NAME=DealFlow

# Email — SMTP fallback (used when RESEND_API_KEY is not set).
# Set ONE of the following config sets, then restart the dev server.
# Recipients see "Your Name <SMTP_FROM_EMAIL>" with replies going to your login email.

# --- Gmail ---
# 1. Enable 2FA at https://myaccount.google.com/security
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM_EMAIL=you@gmail.com

# --- Outlook.com / Hotmail / Live ---
# NOTE: Microsoft retired basic SMTP auth for personal accounts in Sept 2024.
# Only works if you have an App Password set up (account.microsoft.com → Security).
# Microsoft 365 (paid) requires admin re-enabling SMTP AUTH per-mailbox.
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=you@outlook.com
# SMTP_PASS=your-app-password
# SMTP_FROM_EMAIL=you@outlook.com

# --- Yahoo ---
# 1. Enable 2FA in Yahoo Account Security
# 2. Generate an App Password under Account Security → "Generate app password"
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=you@yahoo.com
# SMTP_PASS=your-app-password
# SMTP_FROM_EMAIL=you@yahoo.com
